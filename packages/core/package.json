{
  "name": "@pram1t/mustard-core",
  "version": "1.0.0-rc.3",
  "description": "Core functionality for Mustard - Agent Loop and Context Management",
  "author": "pram1t",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pram1t/Mustard.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/pram1t/Mustard#readme",
  "bugs": {
    "url": "https://github.com/pram1t/Mustard/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@pram1t/mustard-config": "*",
    "@pram1t/mustard-hooks": "*",
    "@pram1t/mustard-logger": "*",
    "@pram1t/mustard-llm": "*",
    "@pram1t/mustard-tools": "*"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "keywords": [
    "openagent",
    "core",
    "agent",
    "llm"
  ]
}
