{
  "name": "@pram1t/mustard-tools",
  "version": "1.0.0-rc.5",
  "description": "Built-in tools for Mustard",
  "author": "pram1t",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pram1t/Mustard.git",
    "directory": "packages/tools"
  },
  "homepage": "https://github.com/pram1t/Mustard#readme",
  "bugs": {
    "url": "https://github.com/pram1t/Mustard/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@types/prompts": "^2.4.9",
    "@types/turndown": "^5.0.6",
    "duck-duck-scrape": "^2.2.7",
    "prompts": "^2.4.2",
    "turndown": "^7.2.2",
    "@pram1t/mustard-config": "*",
    "@pram1t/mustard-logger": "*"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "openagent",
    "tools"
  ]
}
