{
  "name": "@openagent/queue",
  "version": "0.0.0",
  "private": true,
  "description": "In-memory priority task queue with dependency resolution for OpenAgent V2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@openagent/logger": "*",
    "@openagent/message-bus": "*",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.0.9",
    "typescript": "^5.9.3"
  }
}
