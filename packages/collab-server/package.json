{
  "name": "@openagent/collab-server",
  "version": "0.0.0",
  "private": true,
  "description": "Fastify HTTP+WebSocket server for OpenAgent Collab",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@openagent/logger": "*",
    "@openagent/message-bus": "*",
    "@openagent/collab-core": "*",
    "@openagent/collab-ai": "*",
    "@openagent/collab-permissions": "*",
    "@openagent/collab-memory": "*",
    "fastify": "^5.3.3",
    "@fastify/websocket": "^11.0.2",
    "@fastify/cors": "^11.0.0",
    "yjs": "^13.6.0",
    "y-websocket": "^1.5.0",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "@types/better-sqlite3": "^7.6.12",
    "typescript": "^5.9.3"
  }
}
