{
  "name": "@pram1t/mustard-server",
  "version": "1.0.0-rc.4",
  "description": "Fastify HTTP/WebSocket API server for Mustard V2",
  "author": "pram1t",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pram1t/Mustard.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/pram1t/Mustard#readme",
  "bugs": {
    "url": "https://github.com/pram1t/Mustard/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "fastify": "^5.3.3",
    "@fastify/websocket": "^11.0.2",
    "@fastify/cors": "^11.0.0",
    "@pram1t/mustard-logger": "*",
    "@pram1t/mustard-message-bus": "*",
    "@pram1t/mustard-orchestrator": "*",
    "@pram1t/mustard-worker": "*",
    "@pram1t/mustard-queue": "*",
    "@pram1t/mustard-artifact": "*",
    "@pram1t/mustard-memory": "*",
    "@pram1t/mustard-llm": "*",
    "@pram1t/mustard-tools": "*"
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "typescript": "^5.9.3"
  }
}
