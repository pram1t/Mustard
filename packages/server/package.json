{
  "name": "@mustard/server",
  "version": "0.0.0",
  "private": true,
  "description": "Fastify HTTP/WebSocket API server for OpenAgent V2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@mustard/logger": "*",
    "@mustard/message-bus": "*",
    "@mustard/orchestrator": "*",
    "@mustard/worker": "*",
    "@mustard/queue": "*",
    "@mustard/artifact": "*",
    "@mustard/memory": "*",
    "@mustard/llm": "*",
    "@mustard/tools": "*",
    "fastify": "^5.3.3",
    "@fastify/websocket": "^11.0.2",
    "@fastify/cors": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "typescript": "^5.9.3"
  }
}
