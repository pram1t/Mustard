{
  "name": "@pram1t/mustard-llm",
  "version": "1.0.0-rc.2",
  "description": "LLM abstraction layer for Mustard",
  "author": "pram1t",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pram1t/Mustard.git",
    "directory": "packages/llm"
  },
  "homepage": "https://github.com/pram1t/Mustard#readme",
  "bugs": {
    "url": "https://github.com/pram1t/Mustard/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@google/generative-ai": "^0.24.1",
    "openai": "^6.16.0",
    "tiktoken": "^1.0.22",
    "@pram1t/mustard-config": "*",
    "@pram1t/mustard-logger": "*"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "openagent",
    "llm"
  ]
}
