{
  "name": "mustard",
  "version": "1.0.0",
  "description": "Mustard — an open collaborative IDE for human + AI development",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "mcp-servers/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "vitest run --exclude='**/apps/desktop/**' --exclude='**/apps/web/**'",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --exclude='**/apps/desktop/**' --exclude='**/apps/web/**'",
    "lint": "turbo run lint --filter='!@pram1t/mustard-desktop' --filter='!@pram1t/mustard-web'"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.0.9",
    "@vitest/coverage-v8": "^4.0.17",
    "tsx": "^4.21.0",
    "turbo": "^2.7.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "pino": "^10.2.0",
    "pino-pretty": "^13.1.3"
  }
}
