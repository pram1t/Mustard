# OpenAgent Configuration
# Copy this file to .env and fill in your values

# ============================================
# Required: LLM Provider API Keys
# ============================================

# OpenAI API Key (required if using OpenAI provider)
OPENAI_API_KEY=sk-...

# Anthropic API Key (required if using Anthropic provider)
# ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# Optional: Provider Configuration
# ============================================

# Default LLM provider: openai, anthropic, gemini, ollama
# OPENAGENT_PROVIDER=openai

# Default model to use (provider-specific)
# OPENAGENT_MODEL=gpt-4o

# Custom base URL for OpenAI-compatible APIs
# OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================
# Optional: Retry Configuration
# ============================================

# Number of retry attempts on failure (0-10)
# LLM_RETRY_ATTEMPTS=3

# Delay between retries in milliseconds (0-60000)
# LLM_RETRY_DELAY=1000

# ============================================
# Optional: Logging Configuration
# ============================================

# Log level: trace, debug, info, warn, error, fatal, silent
# LOG_LEVEL=info

# Log format: json, pretty
# LOG_FORMAT=pretty

# ============================================
# Optional: Tool Configuration
# ============================================

# Bash command timeout in milliseconds (1000-600000)
# BASH_TIMEOUT=120000

# Maximum bash output size in characters (1000-1000000)
# BASH_MAX_OUTPUT=30000

# Maximum tool output size in characters (1000-1000000)
# MAX_OUTPUT_SIZE=100000

# Comma-separated list of additional allowed environment variables for bash
# BASH_ALLOWED_ENV_VARS=CUSTOM_VAR,ANOTHER_VAR

# ============================================
# Optional: Security Configuration
# ============================================

# Enable audit logging for all tool executions
# AUDIT_LOGGING=false

# Enable input sanitization (path traversal, ReDoS protection)
# SANITIZE_INPUTS=true

# ============================================
# Development
# ============================================

# Environment: development, production, test
# NODE_ENV=development
