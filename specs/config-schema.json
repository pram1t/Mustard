{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openagent.dev/config-schema.json",
  "title": "OpenAgent Configuration",
  "description": "Configuration schema for OpenAgent",
  "type": "object",
  "properties": {
    "llm": {
      "type": "object",
      "description": "LLM provider configuration",
      "properties": {
        "provider": {
          "type": "string",
          "description": "Primary LLM provider",
          "enum": ["openai", "anthropic", "gemini", "ollama", "custom"],
          "default": "openai"
        },
        "fallback": {
          "type": "array",
          "description": "Fallback providers in order",
          "items": {
            "type": "string"
          }
        },
        "openai": {
          "type": "object",
          "properties": {
            "apiKey": {
              "type": "string",
              "description": "OpenAI API key"
            },
            "model": {
              "type": "string",
              "description": "Model to use",
              "default": "gpt-4o"
            },
            "baseURL": {
              "type": ["string", "null"],
              "description": "Custom base URL"
            },
            "organization": {
              "type": ["string", "null"],
              "description": "Organization ID"
            }
          }
        },
        "anthropic": {
          "type": "object",
          "properties": {
            "apiKey": {
              "type": "string",
              "description": "Anthropic API key"
            },
            "model": {
              "type": "string",
              "description": "Model to use",
              "default": "claude-sonnet-4-5-20251101"
            }
          }
        },
        "gemini": {
          "type": "object",
          "properties": {
            "apiKey": {
              "type": "string",
              "description": "Google API key"
            },
            "model": {
              "type": "string",
              "description": "Model to use",
              "default": "gemini-1.5-pro"
            }
          }
        },
        "ollama": {
          "type": "object",
          "properties": {
            "baseURL": {
              "type": "string",
              "description": "Ollama server URL",
              "default": "http://localhost:11434"
            },
            "model": {
              "type": "string",
              "description": "Model to use",
              "default": "llama3.1"
            }
          }
        },
        "custom": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Provider name"
            },
            "baseURL": {
              "type": "string",
              "description": "API base URL"
            },
            "apiKey": {
              "type": "string",
              "description": "API key"
            },
            "model": {
              "type": "string",
              "description": "Model to use"
            }
          },
          "required": ["name", "baseURL", "model"]
        }
      },
      "required": ["provider"]
    },
    "permissions": {
      "type": "object",
      "description": "Permission configuration",
      "properties": {
        "mode": {
          "type": "string",
          "description": "Permission mode",
          "enum": ["default", "strict", "permissive"],
          "default": "default"
        },
        "allow": {
          "type": "array",
          "description": "Rules that automatically allow",
          "items": {
            "$ref": "#/definitions/permissionRule"
          }
        },
        "deny": {
          "type": "array",
          "description": "Rules that automatically deny",
          "items": {
            "$ref": "#/definitions/permissionRule"
          }
        },
        "ask": {
          "type": "array",
          "description": "Rules that prompt for approval",
          "items": {
            "$ref": "#/definitions/permissionRule"
          }
        }
      }
    },
    "hooks": {
      "type": "object",
      "description": "Hook configuration",
      "properties": {
        "session_start": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/hookConfig"
          }
        },
        "user_prompt_submit": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/hookConfig"
          }
        },
        "pre_tool_use": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/hookConfig"
          }
        },
        "post_tool_use": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/hookConfig"
          }
        },
        "notification": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/hookConfig"
          }
        },
        "stop": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/hookConfig"
          }
        }
      }
    },
    "mcp": {
      "type": "object",
      "description": "MCP server configuration",
      "properties": {
        "servers": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/mcpServerConfig"
          }
        }
      }
    },
    "context": {
      "type": "object",
      "description": "Context management configuration",
      "properties": {
        "maxTokens": {
          "type": "number",
          "description": "Maximum tokens for context window",
          "default": 128000
        },
        "compactionThreshold": {
          "type": "number",
          "description": "Threshold to trigger compaction (0-1)",
          "minimum": 0,
          "maximum": 1,
          "default": 0.8
        },
        "preserveRecentCount": {
          "type": "number",
          "description": "Minimum recent messages to preserve",
          "default": 20
        }
      }
    },
    "session": {
      "type": "object",
      "description": "Session configuration",
      "properties": {
        "directory": {
          "type": "string",
          "description": "Session storage directory",
          "default": "~/.openagent/sessions"
        },
        "autoSave": {
          "type": "boolean",
          "description": "Auto-save sessions",
          "default": true
        },
        "autoSaveInterval": {
          "type": "number",
          "description": "Auto-save interval in milliseconds",
          "default": 60000
        }
      }
    },
    "ui": {
      "type": "object",
      "description": "UI configuration",
      "properties": {
        "theme": {
          "type": "string",
          "description": "Color theme",
          "enum": ["auto", "light", "dark"],
          "default": "auto"
        },
        "showTokenCount": {
          "type": "boolean",
          "description": "Show token count in UI",
          "default": true
        },
        "showTimings": {
          "type": "boolean",
          "description": "Show timing information",
          "default": false
        }
      }
    },
    "logging": {
      "type": "object",
      "description": "Logging configuration",
      "properties": {
        "level": {
          "type": "string",
          "description": "Log level",
          "enum": ["debug", "info", "warn", "error"],
          "default": "info"
        },
        "file": {
          "type": ["string", "null"],
          "description": "Log file path"
        }
      }
    }
  },
  "definitions": {
    "permissionRule": {
      "type": "object",
      "properties": {
        "tool": {
          "type": "string",
          "description": "Tool name or pattern"
        },
        "pattern": {
          "type": "boolean",
          "description": "Whether tool is a regex pattern"
        },
        "conditions": {
          "type": "object",
          "properties": {
            "params": {
              "type": "object",
              "description": "Match specific parameter values"
            },
            "pathPattern": {
              "type": "string",
              "description": "Match file path patterns"
            },
            "commandPattern": {
              "type": "string",
              "description": "Match command patterns"
            }
          }
        }
      },
      "required": ["tool"]
    },
    "hookConfig": {
      "type": "object",
      "properties": {
        "command": {
          "type": "string",
          "description": "Shell command to execute"
        },
        "timeout": {
          "type": "number",
          "description": "Timeout in milliseconds"
        },
        "matcher": {
          "type": "object",
          "properties": {
            "tool": {
              "type": "string"
            },
            "toolPattern": {
              "type": "string"
            }
          }
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "cwd": {
          "type": "string"
        }
      },
      "required": ["command"]
    },
    "mcpServerConfig": {
      "type": "object",
      "oneOf": [
        {
          "properties": {
            "type": {
              "const": "stdio"
            },
            "command": {
              "type": "string",
              "description": "Command to run"
            },
            "args": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "cwd": {
              "type": "string"
            },
            "env": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          },
          "required": ["type", "command"]
        },
        {
          "properties": {
            "type": {
              "const": "http"
            },
            "url": {
              "type": "string",
              "description": "Server URL"
            },
            "headers": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          },
          "required": ["type", "url"]
        }
      ]
    }
  }
}
