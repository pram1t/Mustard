{
  "name": "openagent-cli",
  "version": "1.0.0",
  "description": "LLM-agnostic agentic coding assistant — an open-source alternative to Claude Code that works with any provider",
  "author": "pram1t",
  "repository": {
    "type": "git",
    "url": "https://github.com/pram1t/openagent.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/pram1t/openagent#readme",
  "bugs": {
    "url": "https://github.com/pram1t/openagent/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "openagent": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx --watch src/index.ts",
    "clean": "rm -rf dist",
    "start": "tsx src/index.ts"
  },
  "keywords": [
    "openagent",
    "cli",
    "agent",
    "ai",
    "coding-assistant",
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "ollama",
    "mcp",
    "agentic"
  ],
  "license": "MIT",
  "dependencies": {
    "@openagent/artifact": "*",
    "@openagent/config": "*",
    "@openagent/core": "*",
    "@openagent/hooks": "*",
    "@openagent/llm": "*",
    "@openagent/logger": "*",
    "@openagent/mcp": "*",
    "@openagent/memory": "*",
    "@openagent/message-bus": "*",
    "@openagent/orchestrator": "*",
    "@openagent/queue": "*",
    "@openagent/tools": "*",
    "@openagent/server": "*",
    "@openagent/worker": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.9.3"
  }
}
