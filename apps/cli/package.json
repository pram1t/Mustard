{
  "name": "@mustard/cli",
  "version": "1.0.0-rc.1",
  "description": "Mustard CLI — an open collaborative IDE for human + AI development. Works with any LLM provider (OpenAI, Anthropic, Gemini, Ollama, OpenAI-compatible).",
  "author": "pram1t",
  "repository": {
    "type": "git",
    "url": "https://github.com/pram1t/Mustard.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/pram1t/Mustard#readme",
  "bugs": {
    "url": "https://github.com/pram1t/Mustard/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mustard": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx --watch src/index.ts",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "start": "tsx src/index.ts",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "mustard",
    "cli",
    "agent",
    "ai",
    "coding-assistant",
    "collaboration",
    "collab",
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "ollama",
    "mcp",
    "agentic",
    "ide"
  ],
  "license": "MIT",
  "dependencies": {
    "@mustard/artifact": "*",
    "@mustard/config": "*",
    "@mustard/core": "*",
    "@mustard/hooks": "*",
    "@mustard/llm": "*",
    "@mustard/logger": "*",
    "@mustard/mcp": "*",
    "@mustard/memory": "*",
    "@mustard/message-bus": "*",
    "@mustard/orchestrator": "*",
    "@mustard/queue": "*",
    "@mustard/tools": "*",
    "@mustard/server": "*",
    "@mustard/worker": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.9.3"
  }
}
